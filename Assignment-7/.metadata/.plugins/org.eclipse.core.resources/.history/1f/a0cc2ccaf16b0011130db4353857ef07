package com.assignment7;

import java.io.File;
import java.io.IOException;
import java.time.Duration;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;

import org.apache.commons.io.FileUtils;
import org.openqa.selenium.By;
import org.openqa.selenium.OutputType;
import org.openqa.selenium.TakesScreenshot;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.annotations.AfterTest;
import org.testng.annotations.BeforeTest;
import org.testng.annotations.Parameters;
import org.testng.annotations.Test;


public class Assignment_7 {

    WebDriver driver;

    // ✅ Setup Browser (Chrome / Edge)
    @Parameters("browser")
    @BeforeTest
    public void setup() 
    {

        driver = new ChromeDriver();

        driver.manage().window().maximize();

        // ✅ Implicit Wait
        driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));

        driver.get("https://www.spicejet.com/");
    }

    // ✅ Main Test
    @Test
    public void spiceJetBookingFlow() throws Exception {

        // Close popup if exists
        try {
            driver.findElement(By.xpath("//div[contains(@class,'close')]")).click();
        } catch (Exception e) {}

        // ✅ FROM
        driver.findElement(By.xpath("//div[text()='From']")).click();
        WebElement fromInput = driver.findElement(By.xpath("//input[@placeholder='Search']"));
        fromInput.sendKeys("Delhi");
        driver.findElement(By.xpath("//div[text()='Delhi']")).click();

        // ✅ TO
        driver.findElement(By.xpath("//div[text()='To']")).click();
        WebElement toInput = driver.findElement(By.xpath("//input[@placeholder='Search']"));
        toInput.sendKeys("Mumbai");
        driver.findElement(By.xpath("//div[text()='Mumbai']")).click();

        // ✅ DATE (5 days from today)
        LocalDate futureDate = LocalDate.now().plusDays(5);
        String day = futureDate.format(DateTimeFormatter.ofPattern("d"));

        driver.findElement(By.xpath("//div[@data-testid='departure-date-dropdown-label-test-id']")).click();
        driver.findElement(By.xpath("//div[@data-testid='undefined-calendar-day-" + day + "']")).click();

        // ✅ PASSENGERS (5 Adults)
        driver.findElement(By.xpath("//div[text()='Passengers']")).click();

        for (int i = 1; i < 5; i++) {
            driver.findElement(By.xpath("//div[@data-testid='Adult-testID-plus-one-cta']")).click();
        }

        driver.findElement(By.xpath("//div[text()='Done']")).click();

        // ✅ SEARCH
        driver.findElement(By.xpath("//div[text()='Search Flight']")).click();

        Thread.sleep(5000);

        // ✅ SELECT FIRST FLIGHT
        driver.findElement(By.xpath("(//div[contains(@class,'flight')])[1]")).click();

        // ✅ CONTINUE
        driver.findElement(By.xpath("//div[text()='Continue']")).click();

        // ✅ CONTACT DETAILS
        driver.findElement(By.xpath("//input[@placeholder='Mobile Number']")).sendKeys("9999999999");
        driver.findElement(By.xpath("//input[@placeholder='Email']")).sendKeys("test@gmail.com");

        // ✅ PASSENGER DETAILS
        driver.findElement(By.xpath("(//input[@placeholder='First Name'])[1]")).sendKeys("Bappi");
        driver.findElement(By.xpath("(//input[@placeholder='Last Name'])[1]")).sendKeys("Gorain");

        // ✅ FINAL CONTINUE
        driver.findElement(By.xpath("//div[text()='Continue']")).click();

        // ✅ SCREENSHOT
        takeScreenshot("SpiceJet_Booking");
    }

    // ✅ Screenshot Method
    public void takeScreenshot(String fileName) throws IOException {

        File src = ((TakesScreenshot) driver).getScreenshotAs(OutputType.FILE);
        FileUtils.copyFile(src, new File("./Screenshots/" + fileName + ".png"));
    }

    // ✅ Tear Down
    @AfterTest
    public void tearDown() {
        driver.quit();
    }
}